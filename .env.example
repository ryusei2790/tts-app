# Google Cloud サービスアカウントのJSONキー（1行のJSON文字列として設定）
# 取得方法: GCP Console → IAM → サービスアカウント → キーを作成 → JSON
# 1行化コマンド: cat your-key.json | tr -d '\n'
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"YOUR_PROJECT_ID",...}

# Gemini API キー（要約機能で使用）
# 取得方法: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
